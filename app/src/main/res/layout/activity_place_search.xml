<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/orbit_space"
    android:padding="16dp">

    <EditText
        android:id="@+id/inputPlaceSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/place_search_hint"
        android:inputType="text"
        android:textColor="@color/white"
        android:textColorHint="@color/orbit_text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/placeSearchStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/place_search_helper"
        android:textColor="@color/orbit_text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/inputPlaceSearch" />

    <FrameLayout
        android:id="@+id/placeMapFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:background="@color/orbit_surface_light"
        app:layout_constraintBottom_toTopOf="@id/placeResultList"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/placeSearchStatus">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/placeMapContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/placeMapPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="18dp"
            android:text="@string/place_search_map_missing"
            android:textAlignment="center"
            android:textColor="@color/orbit_text_secondary" />
    </FrameLayout>

    <ListView
        android:id="@+id/placeResultList"
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:layout_marginTop="10dp"
        android:background="@color/orbit_surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
