<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/orbit_space"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="56dp"
    android:clipToPadding="false">

    <!-- Header -->
    <ImageButton
        android:id="@+id/btnBackToGenerate"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="New Plan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/generatedTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBackToGenerate"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBackToGenerate"
        app:layout_constraintTop_toTopOf="@id/btnBackToGenerate" />

    <TextView
        android:id="@+id/plannerStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/orbit_text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBackToGenerate" />

    <!-- Google Map panel -->
    <FrameLayout
        android:id="@+id/plannerMapPanel"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="12dp"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/plannerStatus">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/plannerMapFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/plannerMapKeyPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/orbit_surface_light"
            android:gravity="center"
            android:padding="18dp"
            android:text="@string/record_map_key_missing"
            android:textAlignment="center"
            android:textColor="@color/orbit_text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Daily Timeline ViewPager2 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/dayPlanPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/plannerMapPanel" />

</androidx.constraintlayout.widget.ConstraintLayout>
