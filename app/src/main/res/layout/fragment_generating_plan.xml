<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/orbit_space"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="56dp"
    android:clipToPadding="false">

    <!-- INPUT PHASE LAYOUT -->
    <ScrollView
        android:id="@+id/layoutInputs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="visible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/plannerTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="AI Travel Planner"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Destination input -->
            <EditText
                android:id="@+id/inputDestination"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/planner_destination_hint"
                android:inputType="text"
                android:focusable="false"
                android:clickable="true"
                android:drawableEnd="@android:drawable/ic_menu_search"
                android:drawableTint="@color/orbit_text_secondary"
                android:textColor="@color/white"
                android:textColorHint="@color/orbit_text_secondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/plannerTitle" />

            <!-- Days input -->
            <EditText
                android:id="@+id/inputDays"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/planner_days_hint"
                android:inputType="number"
                android:textColor="@color/white"
                android:textColorHint="@color/orbit_text_secondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/inputDestination" />

            <!-- Style selection -->
            <TextView
                android:id="@+id/labelStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Style Preferences"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/inputDays" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/labelStyle">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipExtreme"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Extreme"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFood"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Food"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipNature"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nature"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCulture"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Culture"
                    android:checkable="true" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Radius selection -->
            <TextView
                android:id="@+id/labelRadius"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Search Radius (검색 반경)"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/chipGroupStyle" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupRadius"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/labelRadius">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRadius1"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 km"
                    android:tag="1.0"
                    android:checkable="true"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRadius15"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.5 km"
                    android:tag="1.5"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRadius3"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 km"
                    android:tag="3.0"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRadius5"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 km"
                    android:tag="5.0"
                    android:checkable="true" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Generate recommendations trigger button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFindRecommendations"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="추천 장소 조회하기"
                android:textColor="@color/orbit_space"
                app:backgroundTint="@color/orbit_primary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/chipGroupRadius" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- CARD SELECTION PHASE LAYOUT -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutRecommendations"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Small Header -->
        <ImageButton
            android:id="@+id/btnBackToInputs"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Go Back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtRecommendationSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBackToInputs"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBackToInputs"
            app:layout_constraintTop_toTopOf="@id/btnBackToInputs" />

        <!-- Cards ViewPager2 -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/recommendationsPager"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toTopOf="@id/txtSelectedCount"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBackToInputs" />

        <!-- Selected count -->
        <TextView
            android:id="@+id/txtSelectedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="선택된 장소: 0개"
            android:textColor="@color/orbit_text_secondary"
            android:textSize="14sp"
            app:layout_constraintBottom_toTopOf="@id/btnConfirmItinerary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Bottom confirmation button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmItinerary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="선택된 장소로 일정 확정하기"
            android:textColor="@color/orbit_space"
            android:enabled="false"
            app:backgroundTint="@color/orbit_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- LOADING & ERROR OVERLAY -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/orbit_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#FF6B6B"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
