<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_add_trip_panel"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/photoBlockTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/section_photos"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonDeletePhotoBlock"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/button_delete" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="520dp"
        android:layout_marginTop="10dp"
        android:background="@color/orbit_surface">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/photoBlockPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

        <TextView
            android:id="@+id/photoBlockEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/photo_block_empty"
            android:textAlignment="center"
            android:textColor="@color/orbit_text_secondary"
            android:textSize="14sp" />
    </FrameLayout>
</LinearLayout>
